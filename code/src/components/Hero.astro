---
import Header from "./header.astro";
import heroImage from "../assets/heroImage.jpeg";
import Footer from "./footer.astro";
---

<main class="hero">
  <Header />
  <div class="hero-content">
    <div class="hero-text">
      <h2>Club Ciclista</h2>
      <h1>Bidebieta</h1>
      <h3>
        Unidos por el ciclismo, el paisaje y... el final de cada salida 🍻😜
      </h3>
    </div>
    <div class="hero-image">
      <img
        src={heroImage}
        alt="Fotografía de los socios fundadores del Club Ciclista Bidebieta"
      /> 
    </div>
    <br>
  </div>
  <Footer />
</main>

<style>
  .hero {
    width: 100vw;
    height: 95vh;
    background-image: radial-gradient(
        var(--background-light) 1px,
        transparent 11%
      ),
      radial-gradient(var(--background-light) 1px, transparent 0);
    background-size: 60px 60px;
    background-position: 0 0, 30px 30px;
    background-repeat: repeat;
  }

  .hero-content {
    width: min(80%, 1530px);
    margin-top: 12vh;
    margin-inline: auto;

    display: grid;
    grid-template-columns: 60% 30%;
    grid-template-rows: 1fr;
    column-gap: 5%;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-text > h2 {
    font-family: 'TelefanteBlack';
    font-size: 6rem;
    font-weight: 700;
    text-decoration: underline solid var(--primary-color);
  }

  .hero-text > h1 {
    font-size: 10rem;
    font-weight: 700;
    color: var(--brand-color);
    font-family: 'TelefanteBlack';
  }

  .hero-text > h3 {
    font-size: 2.3rem;
    font-weight: 500;
    line-height: 1.4em;
  }

  .hero-image > img {
    width: 100%;
    object-fit: cover;
    border-radius: 1.5rem;

    box-shadow: rgba(0, 0, 0, 0.25) 0px 54px 55px,
      rgba(0, 0, 0, 0.12) 0px -12px 30px, rgba(0, 0, 0, 0.12) 0px 4px 6px,
      rgba(0, 0, 0, 0.17) 0px 12px 13px, rgba(0, 0, 0, 0.09) 0px -3px 5px;
  }
</style>
